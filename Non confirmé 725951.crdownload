$projectPath = Split-Path -Parent $MyInvocation.MyCommand.Path
Set-Location $projectPath

Write-Host "Lancement de La Galerie des Livres..." -ForegroundColor Cyan

$port = 8080
$url = "http://localhost:$port/index.html"

try {
    Start-Process $url
    python -m http.server $port | Out-Null
}
catch {
    Write-Host "Python n'est pas disponible dans le PATH." -ForegroundColor Red
    Write-Host "Ouvre simplement index.html dans ton navigateur, ou installe Python." -ForegroundColor Yellow
}
